:root {
  --bg-top: #fff7e8;
  --bg-bottom: #ffd29b;
  --panel: rgba(255, 248, 236, 0.92);
  --panel-strong: #fff3df;
  --ink: #2d1b11;
  --muted: #7c5c47;
  --accent: #f36c3d;
  --accent-deep: #c5451f;
  --accent-soft: #ffd8c6;
  --success: #1e9c68;
  --border: rgba(94, 52, 33, 0.14);
  --shadow: 0 18rpx 44rpx rgba(112, 54, 23, 0.12);
  --radius-xl: 32rpx;
  --radius-lg: 24rpx;
  --radius-md: 18rpx;
}

page {
  min-height: 100%;
  background: linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
  color: var(--ink);
  font-family: "Trebuchet MS", "Avenir Next", "PingFang SC", sans-serif;
}

.page-shell {
  padding: 32rpx 24rpx 48rpx;
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: var(--panel);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
}

.section-kicker {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: var(--accent-deep);
}

.section-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.section-copy {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--muted);
}

.button-primary,
.button-secondary,
.chip-button {
  border: none;
  border-radius: 999rpx;
}

.button-primary::after,
.button-secondary::after,
.chip-button::after {
  border: none;
}

.button-primary {
  background: linear-gradient(135deg, var(--accent) 0%, #ff8b52 100%);
  color: #fff8f0;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(243, 108, 61, 0.24);
}

.button-primary[disabled] {
  background: #e8cfbc;
  color: rgba(45, 27, 17, 0.45);
  box-shadow: none;
}

.button-secondary {
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink);
  border: 2rpx solid rgba(94, 52, 33, 0.12);
}

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--muted);
  font-size: 24rpx;
}
