.play-shell {
  position: relative;
  padding-top: 28rpx;
  padding-bottom: 56rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.play-shell > view {
  position: relative;
  z-index: 1;
}

/* ---------- Header / progress ---------- */
.play-header {
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.96) 0%, rgba(248, 235, 211, 0.92) 100%);
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-soft);
  animation: rise-in 0.35s var(--ease) both;
}

.play-phase-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.play-phase {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(184, 91, 63, 0.1);
  border: 2rpx solid rgba(184, 91, 63, 0.18);
  color: var(--accent-deep);
  font-size: 24rpx;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.play-phase-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 0 rgba(184, 91, 63, 0.5);
  animation: pulse-soft 1.6s ease-in-out infinite;
}

.play-phase-dot-done {
  background: var(--success);
  animation: none;
  box-shadow: 0 0 0 6rpx rgba(47, 140, 105, 0.18);
}

.play-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  color: var(--ink);
}

.play-count-num {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  color: var(--accent-deep);
}

.play-count-total {
  font-size: 24rpx;
  color: var(--muted);
}

.play-count-label {
  margin-left: 8rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--muted-2);
}

.play-progress {
  margin-top: 16rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(124, 53, 38, 0.12);
  overflow: hidden;
}

.play-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f4c56f 0%, #e69b6f 50%, #cf7756 100%);
  border-radius: 999rpx;
  box-shadow: 0 0 12rpx rgba(244, 197, 111, 0.45);
  transition: width 0.4s var(--ease);
}

.play-hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
  line-height: 1.5;
}
