.play-shell {
  position: relative;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 24%),
    linear-gradient(180deg, var(--table-top) 0%, var(--table-bottom) 100%);
}

.play-shell::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
  background-size: 24rpx 24rpx;
  pointer-events: none;
}
