.play-shell {
  position: relative;
  background:
    radial-gradient(circle at 50% -5%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(80% 40% at 110% 110%, rgba(201, 147, 81, 0.18) 0%, rgba(201, 147, 81, 0) 60%),
    linear-gradient(180deg, var(--table-top) 0%, var(--table-bottom) 100%);
  padding-top: 28rpx;
  padding-bottom: 56rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.play-shell::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
  background-size: 28rpx 28rpx;
  pointer-events: none;
}

.play-shell > view {
  position: relative;
  z-index: 1;
}

/* ---------- Header / progress ---------- */
.play-header {
  padding: 22rpx 26rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 244, 223, 0.08) 0%, rgba(255, 244, 223, 0.02) 100%);
  border: 2rpx solid rgba(255, 244, 223, 0.14);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(4rpx);
  animation: rise-in 0.35s var(--ease) both;
}

.play-phase-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.play-phase {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 223, 0.12);
  border: 2rpx solid rgba(255, 244, 223, 0.18);
  color: #fff5e2;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.play-phase-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f4c56f;
  box-shadow: 0 0 0 0 rgba(244, 197, 111, 0.5);
  animation: pulse-soft 1.6s ease-in-out infinite;
}

.play-phase-dot-done {
  background: #7de0a7;
  animation: none;
  box-shadow: 0 0 0 6rpx rgba(125, 224, 167, 0.18);
}

.play-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  color: #fff5e2;
}

.play-count-num {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  color: #ffd79a;
}

.play-count-total {
  font-size: 24rpx;
  color: rgba(255, 245, 226, 0.7);
}

.play-count-label {
  margin-left: 8rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 245, 226, 0.6);
}

.play-progress {
  margin-top: 16rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 223, 0.14);
  overflow: hidden;
}

.play-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f4c56f 0%, #e69b6f 50%, #cf7756 100%);
  border-radius: 999rpx;
  box-shadow: 0 0 12rpx rgba(244, 197, 111, 0.45);
  transition: width 0.4s var(--ease);
}

.play-hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 245, 226, 0.78);
  letter-spacing: 1rpx;
}
