<view class="page-shell play-shell">
  <player-card-grid
    players="{{players}}"
    game-phase="{{gamePhase}}"
    viewed-count="{{viewedCount}}"
    bind:cardtap="onCardTap"
  />

  <reveal-panel
    can-reveal="{{canReveal}}"
    game-phase="{{gamePhase}}"
    bind:reveal="onReveal"
    bind:nextround="onNextRound"
    bind:reset="onReset"
  />
</view>
