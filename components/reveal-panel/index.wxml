<view class="section-card">
  <view class="action-row">
    <button
      wx:if="{{gamePhase === 'revealed'}}"
      class="button-primary compact-button"
      hover-class="button-hover"
      bindtap="onNextRound"
    >
      再来一局
    </button>
    <button
      wx:else
      class="button-primary compact-button"
      hover-class="button-hover"
      disabled="{{!canReveal}}"
      bindtap="onReveal"
    >
      揭开谜底
    </button>
    <button
      class="button-secondary compact-button"
      hover-class="button-hover"
      bindtap="onReset"
    >
      重新设置
    </button>
  </view>
</view>
