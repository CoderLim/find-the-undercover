.setup-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 690rpx;
}

.picker-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx 28rpx 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 246, 0.98) 0%, rgba(246, 232, 208, 0.96) 100%);
  border: 2rpx solid rgba(104, 65, 43, 0.12);
  border-radius: 30rpx;
  box-shadow: var(--shadow);
}

.picker-card::after {
  content: "";
  position: absolute;
  right: -32rpx;
  bottom: -42rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(184, 91, 63, 0.08);
}

.picker-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: var(--muted);
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
}

.picker-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink);
}

.picker-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(184, 91, 63, 0.12);
  box-shadow: inset 0 0 0 2rpx rgba(184, 91, 63, 0.08);
  font-size: 38rpx;
  color: var(--accent-deep);
  line-height: 1;
}

.start-button {
  margin-top: 6rpx;
  height: 102rpx;
  line-height: 102rpx;
  border-radius: 30rpx;
  box-shadow: var(--shadow-heavy);
}
